{
  "name": "@durust/eslint-plugin",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.json"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root ../.. --config vitest.config.ts packages/eslint-plugin/test"
  },
  "peerDependencies": {
    "eslint": ">=8.57.0 || >=9.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danthegoodman1/durust.git"
  }
}
