  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --root ../.. --config vitest.config.ts packages/sqlite/test"
  },
  "devDependencies": {
    "@durust/payload": "^0.0.0",
    "@durust/testing": "^0.0.0"
